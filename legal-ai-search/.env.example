# AI Legal Research Assistant - Environment Variables
# Copy this file to .env and fill in your actual values

# Google Gemini Configuration
GEMINI_API_KEY=AIzaSyACdkZ3qSDfKYVrtXjXNfxeFlr2Im7hhOg

# Endee Vector Database Configuration
ENDEE_API_KEY=your_endee_api_key_here
ENDEE_URL=https://api.endee.io/v1

# API Configuration (Optional - defaults provided)
API_HOST=0.0.0.0
API_PORT=8000

# Google Gemini Models (Optional - defaults provided)
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# Database Paths (Optional - defaults provided)
VECTOR_DB_PATH=./data/vector_db
QUERY_HISTORY_DB=./data/query_history.db
DOCUMENTS_PATH=./data/documents

# Search Configuration (Optional - defaults provided)
VECTOR_WEIGHT=0.7
KEYWORD_WEIGHT=0.3
TOP_K_RESULTS=5

# Performance Settings (Optional - defaults provided)
ENABLE_PERFORMANCE_LOGGING=true
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
